# ============================================
# CineMatch Poster Generation - Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Azure OpenAI ---
# Your Azure OpenAI service endpoint
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
# Your Azure OpenAI API key
AZURE_API_KEY=your-api-key-here
# GPT-4o deployment name (default: gpt-4o)
AZURE_GPT4O_DEPLOYMENT=gpt-4o
# DALL-E deployment name (default: gpt-image-1-mini)
AZURE_DALLE_DEPLOYMENT=gpt-image-1-mini

# --- Storage ---
# Storage mode: "local" or "s3" (default: local)
STORAGE_MODE=local
# Local path for generated poster images (default: generated_posters)
LOCAL_STORAGE_PATH=generated_posters
# Local path for enhanced poster images (default: enhanced_posters)
ENHANCED_STORAGE_PATH=enhanced_posters

# --- Generation ---
# DALL-E image size (default: 1024x1024)
IMAGE_SIZE=1024x1024
# Maximum concurrent generations (default: 2)
MAX_CONCURRENT=2
# Maximum retry attempts on failure (default: 3)
RETRY_COUNT=3
# Enable post-production image enhancement (default: true)
ENABLE_ENHANCEMENT=true

# --- TMDB ---
# Base URL for TMDB poster images (default: https://image.tmdb.org/t/p/original)
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/original

# --- Cloudflare R2 (optional) ---
# Required only if STORAGE_MODE=s3 or upload_cloud=true
# Your Cloudflare R2 account ID
R2_ACCOUNT_ID=
# Your Cloudflare R2 access key ID
R2_ACCESS_KEY=
# Your Cloudflare R2 secret access key
R2_SECRET_KEY=
# Cloudflare R2 bucket name (default: cinematch-posters)
R2_BUCKET_NAME=cinematch-posters
# Cloudflare R2 public URL (optional)
R2_PUBLIC_URL=